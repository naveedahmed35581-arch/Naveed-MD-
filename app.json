      "value": "https://files.catbox.moe/x2qij1.jpg"
    },
    "LIVE_MSG": {
      "description": "Alive message text.",
      "required": false,
      "value": "> I'm alive*NAVEED-MD*🇵🇰"
    },
    "READ_MESSAGE": {
      "description": "Automatically read all messages.",
      "required": false,
      "value": "false"
