    "AUTO_VOICE": {
      "description": "Enable auto-voice replies.",
      "required": false,
      "value": "false"
    },
    "AUTO_STICKER": {
      "description": "Enable auto-sticker replies.",
      "required": false,
      "value": "false"
    },
    "AUTO_REPLY": {
      "description": "Enable auto-reply.",
      "required": false,
      "value": "false"
    },
    "ALWAYS_ONLINE": {
      "description": "Keep bot status always online.",
      "required": false,
      "value": "false"
    },
    "PUBLIC_MODE": {
      "description": "Enable public mode.",
      "required": false,
      "value": "true"
    },
    "AUTO_TYPING": {
      "description": "Show typing status automatically.",
      "required": false,
      "value": "false"
    },
    "READ_CMD": {
      "description": "Automatically read commands.",
      "required": false,
      "value": "false"
    },
    "DEV": {
      "description": "Developer's WhatsApp number.",
      "required": false,
      "value": "923035512967"
    },
    "ANTI_VV": {
      "description": "Enable anti-view once protection.",
      "required": false,
      "value": "true"
    },
    "ANTI_CALL": {
      "description": "Reject incoming calls automatically.",
      "required": false,
      "value": "false"
    },
    "REJECT_MSG": {
      "description": "Message sent when a call is rejected.",
      "required": false,
      "value": "*Access denied. You are not allowed to use this bot.*"
    },
    "ANTI_DELETE": {
      "description": "Enable anti-delete protection.",
      "required": false,
      "value": "true"
    },
    "ANTI_DEL_PATH": {
      "description": "Path to send deleted messages.",
      "required": false,
      "value": "same"
    },
    "AUTO_RECORDING": {
      "description": "Show recording status automatically.",
      "required": false,
      "value": "false"
    },
    "ANTI_LINK_KICK": {
      "description": "Kick users who send links.",
      "required": false,
      "value": "false"
    },
    "ANTI_LINK_ACTION": {
      "description": "Action for anti-link (warn/kick/delete).",
      "required": false,
      "value": "warn"
    },
    "ANTI_EDIT": {
      "description": "Enable anti-edit protection.",
      "required": false,
      "value": "false"
    },
    "ANTI_EDIT_PATH": {
      "description": "Path to send edited messages.",
      "required": false,
      "value": "inbox"
    },
    "ANTI_PROMOTE": {
      "description": "Enable anti-promote protection.",
      "required": false,
      "value": "false"
    },
    "ANTI_FORIGN": {
      "description": "Enable anti-foreign numbers protection.",
      "required": false,
      "value": "false"
    },
    "ANTI_FORIGN_NUMBER": {
      "description": "Country code prefix for foreign numbers.",
      "required": false,
      "value": "92"
    },
    "ADMIN_USE": {
      "description": "Restrict bot usage to admins only.",
      "required": false,
      "value": "false"
    },
    "AUTO_DOWNLOAD": {
      "description": "Enable auto-downloading of media.",
      "required": false,
      "value": "false"
    },
    "AUTO_STATUS_REACT_EMOJIS": {
      "description": "Emojis list for auto status reactions.",
      "required": false,
      "value": "💝,💖,💗,❤️,🧡,💛,💚,💙"
    }
  },
  "buildpacks": [
    {
      "url": "https://github.com/heroku/heroku-buildpack-nodejs.git"
    }
  ],
  "stack": "heroku-24"
}