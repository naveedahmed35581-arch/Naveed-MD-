{
  "name": "Naveed-MD",
  "description": "Javascript WhatsApp bot powered by Naveed",
  "logo": "https://cdn-bandaheali.zone.id/edith/alive.jpg",
  "keywords": ["Naveed-MD", "WhatsApp Bot"],
  "success_url": "/",
  "env": {
    "SESSION_ID": {
      "description": "Put your Baileys session-id here (Base64).",
      "required": true,
      "value": ""
    },
    "START_IMG": {
      "description": "Start image URL.",
      "required": false,
      "value": "https://cdn.inprnt.com/thumbs/5d/0b/5d0b7faa113233d7c2a49cd8dbb80ea5@2x.jpg"
    },
    "AUTO_STATUS_SEEN": {
      "description": "Automatically view status updates.",
      "required": false,
      "value": "true"
    },
    "AUTO_STATUS_REPLY": {
      "description": "Automatically reply to status updates.",
      "required": false,
      "value": "false"
    },
    "AUTO_STATUS_REACT": {
      "description": "Automatically react to status updates.",
      "required": false,
      "value": "false"
    },
    "AUTO_STATUS_MSG": {
      "description": "Message to send when status is viewed.",
      "required": false,
      "value": "*SEEN YOUR STATUS BY NAVEED-MD 🇵🇰*"
    },
    "WELCOME": {
      "description": "Enable welcome message for new group members.",
      "required": false,
      "value": "false"
    },
    "ADMIN_EVENTS": {
      "description": "Enable admin events notifications.",
      "required": false,
      "value": "false"
    },
    "PREFIX": {
      "description": "Bot command prefix.",
      "required": false,
      "value": "."
    },
    "MENTION_REPLY": {
      "description": "Enable reply when bot is mentioned.",
      "required": false,
      "value": "false"
    },
    "MENU_IMAGE_URL": {
      "description": "URL of the menu image.",
      "required": false,
      "value": "https://bandaheali-cdn.koyeb.app/bandaheali/smd.jpg"
    },
    "BOT_NAME": {
      "description": "Name of the bot.",
      "required": false,
      "value": "NAVEED-MD"
    },
    "STICKER_NAME": {
      "description": "Default sticker pack name.",
      "required": false,
      "value": "NAVEED-MD"
    },
    "CUSTOM_REACT": {
      "description": "Enable custom reactions.",
      "required": false,
      "value": "false"
    },
    "CUSTOM_REACT_EMOJIS": {
