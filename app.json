    "AUTO_REACT": {
      "description": "Automatically react to messages.",
      "required": false,
      "value": "false"
    },
    "ANTI_BAD": {
      "description": "Enable anti-bad words filter.",
      "required": false,
      "value": "false"
    },
    "MODE": {
      "description": "Bot mode (public/private).",
      "required": false,
      "value": "public"
