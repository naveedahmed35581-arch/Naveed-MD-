      "description": "Delete links sent in groups.",
      "required": false,
      "value": "false"
    },
    "OWNER_NUMBER": {
      "description": "Owner's WhatsApp number.",
      "required": false,
      "value": "923035512967"
    },
    "OWNER_NAME": {
      "description": "Owner's name.",
      "required": false,
      "value": "NAVEED-MD"
    },
    "DESCRIPTION": {
      "description": "Bot description.",
      "required": false,
      "value": "*©ᴘᴏᴡᴇʀᴇᴅ ʙʏ ɴᴀᴠᴇᴇᴅ-ᴍᴅ*"
    },
